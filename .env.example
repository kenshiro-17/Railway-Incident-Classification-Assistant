# =========================================================
# Railway Incident Classification Assistant - .env.example
# =========================================================

# -------------------------
# App / Runtime
# -------------------------
RIA_ENVIRONMENT=dev

# -------------------------
# Gemini
# -------------------------
RIA_GEMINI_MODEL=gemini-2.0-flash
RIA_GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# Optional override:
# RIA_GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models

# -------------------------
# Prompting / Orchestration
# -------------------------
RIA_PROMPT_TEMPLATE_VERSION=v1.0.0
RIA_THRESHOLD_LOW_CONFIDENCE=0.65
RIA_MAX_CLARIFICATION_TURNS=2

# -------------------------
# SSO / Auth
# -------------------------
# Use "stub" for local dev, "jwt" for production.
RIA_SSO_MODE=stub
RIA_REQUIRE_JWT_IN_PROD=true
RIA_SSO_JWKS_URL=
RIA_SSO_ISSUER=
RIA_SSO_AUDIENCE=
RIA_SSO_USER_CLAIM=sub
RIA_SSO_ROLE_CLAIM=role

# -------------------------
# CORS / Host Security
# -------------------------
RIA_ALLOWED_ORIGINS=http://localhost:8000
RIA_TRUSTED_HOSTS=localhost,127.0.0.1
RIA_MAX_REQUEST_BYTES=65536

# -------------------------
# Rate Limiting - Burst
# -------------------------
RIA_BURST_WINDOW_SECONDS=60
RIA_BURST_LIMIT_PER_USER=20
RIA_BURST_LIMIT_PER_IP=40
RIA_BURST_LIMIT_GLOBAL=500

# -------------------------
# Rate Limiting - Sustained
# -------------------------
RIA_SUSTAINED_WINDOW_SECONDS=3600
RIA_SUSTAINED_LIMIT_PER_USER=300
RIA_SUSTAINED_LIMIT_PER_IP=600
RIA_SUSTAINED_LIMIT_GLOBAL=10000

# -------------------------
# DDoS Guard
# -------------------------
RIA_DDOS_BLOCK_AFTER_VIOLATIONS=25
RIA_DDOS_BLOCK_WINDOW_SECONDS=300
RIA_DDOS_BLOCK_DURATION_SECONDS=900

# -------------------------
# Prompt Injection Strict Mode
# -------------------------
RIA_PROMPT_INJECTION_STRICT_MODE=true
RIA_PROMPT_INJECTION_MAX_ATTEMPTS=3
RIA_PROMPT_INJECTION_WINDOW_SECONDS=600
RIA_PROMPT_INJECTION_QUARANTINE_SECONDS=1800

# -------------------------
# Audit / Retention
# -------------------------
RIA_AUDIT_LOG_PATH=app/data/audit.log
RIA_RAW_RETENTION_DAYS=7
RIA_STRUCTURED_RETENTION_DAYS=90

# -------------------------
# Evaluation Gates
# -------------------------
RIA_CRITICAL_RECALL_THRESHOLD=0.95
RIA_TOP1_ACCURACY_THRESHOLD=0.80
RIA_ESCALATION_FNR_THRESHOLD=0.02
RIA_P95_LATENCY_THRESHOLD_SECONDS=5.0

# -------------------------
# Shared State / Redis
# -------------------------
RIA_REDIS_URL=
RIA_STATE_TTL_SECONDS=7200

# -------------------------
# Provider Failsafe
# -------------------------
RIA_FALLBACK_PROVIDER_ENABLED=true
RIA_GEMINI_FAIL_CLOSED_IN_PROD=false
RIA_GEMINI_TIMEOUT_SECONDS=25

# -------------------------
# Internal / mTLS
# -------------------------
RIA_INTERNAL_API_TOKEN=
RIA_REQUIRE_MTLS_FOR_INTERNAL=false
RIA_MTLS_VERIFIED_HEADER=X-Client-Cert-Verified

# -------------------------
# WAF / Reputation
# -------------------------
RIA_WAF_ENABLED=true
RIA_IP_BLOCKLIST_PATH=app/data/ip_blocklist.txt

# -------------------------
# Telemetry (OpenTelemetry)
# -------------------------
RIA_OTEL_ENABLED=false
RIA_OTEL_SERVICE_NAME=ria-assistant
RIA_OTEL_EXPORTER_OTLP_ENDPOINT=

# -------------------------
# Audit Signing
# -------------------------
RIA_AUDIT_SIGNING_KEY=
RIA_SECRETS_ENCRYPTION_KEY=
